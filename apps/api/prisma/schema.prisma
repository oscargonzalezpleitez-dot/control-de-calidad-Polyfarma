// ============================================================
// PharmaQMS - Schema de Base de Datos
// Cumplimiento: 21 CFR Part 11, EU GMP Annex 11, ALCOA+
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUARIOS Y AUTENTICACIÓN
// ============================================================

enum UserRole {
  ADMIN
  QUALITY
  PRODUCTION
  DEVELOPMENT
  MICROBIOLOGY
  QUALITY_CONTROL
  REGULATORY_AFFAIRS
  AUDITOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PENDING_ACTIVATION
}

model User {
  id                    String     @id @default(cuid())
  email                 String     @unique
  username              String     @unique
  passwordHash          String
  firstName             String
  lastName              String
  role                  UserRole
  status                UserStatus @default(PENDING_ACTIVATION)
  department            String?
  position              String?
  employeeId            String?    @unique
  phone                 String?

  // MFA (21 CFR Part 11)
  mfaEnabled            Boolean    @default(false)
  mfaSecret             String?
  mfaBackupCodes       String[]

  // Control de sesiones
  loginAttempts         Int        @default(0)
  lockedUntil           DateTime?
  lastLoginAt           DateTime?
  lastLoginIp           String?
  passwordChangedAt     DateTime   @default(now())
  mustChangePassword    Boolean    @default(false)
  passwordExpiresAt     DateTime?

  // Firma electrónica (21 CFR Part 11)
  signatureEnabled      Boolean    @default(false)
  signaturePin          String?

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  createdBy             String?
  isDeleted             Boolean    @default(false)
  deletedAt             DateTime?
  deletedBy             String?

  // Relaciones
  permissions           UserPermission[]
  sessions              Session[]
  auditLogs             AuditLog[]
  signatures            ElectronicSignature[]
  createdFormats        Format[]             @relation("FormatCreator")
  approvedFormats       FormatApproval[]
  createdRecords        Record[]             @relation("RecordCreator")
  recordValues          RecordFieldValue[]
  generatedReports      Report[]
  passwordHistory       PasswordHistory[]

  @@map("users")
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@map("password_history")
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  token        String    @unique
  refreshToken String?   @unique
  ipAddress    String
  userAgent    String?
  isActive     Boolean   @default(true)
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?
  revokedBy    String?

  user         User      @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model UserPermission {
  id         String   @id @default(cuid())
  userId     String
  module     String
  action     String
  granted    Boolean  @default(true)
  grantedBy  String
  grantedAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, module, action])
  @@map("user_permissions")
}

// ============================================================
// FORMATOS Y PLANTILLAS
// ============================================================

enum FormatStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  OBSOLETE
  SUPERSEDED
}

enum FormatType {
  FORM
  CHECKLIST
  LOG
  PROTOCOL
  REPORT_TEMPLATE
  CERTIFICATE
  SOP
  BATCH_RECORD
}

enum FieldType {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  DATETIME
  TIME
  SELECT
  MULTISELECT
  CHECKBOX
  RADIO
  SIGNATURE
  FILE_UPLOAD
  IMAGE
  CALCULATED
  LABEL
  SEPARATOR
  TABLE
}

model Format {
  id              String       @id @default(cuid())
  code            String       @unique
  name            String
  description     String?
  type            FormatType
  status          FormatStatus @default(DRAFT)
  version         String       @default("1.0")
  department      String?
  effectiveDate   DateTime?
  expirationDate  DateTime?
  retentionPeriod Int?

  // Plantilla base
  templateFile    String?
  templateType    String?

  // Control de versiones
  previousVersionId String?
  previousVersion   Format?     @relation("FormatVersions", fields: [previousVersionId], references: [id])
  nextVersions      Format[]    @relation("FormatVersions")

  isDeleted         Boolean     @default(false)
  deletedAt         DateTime?
  deletedBy         String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  createdById       String
  updatedById       String?

  // Relaciones
  createdBy         User        @relation("FormatCreator", fields: [createdById], references: [id])
  fields            FormatField[]
  approvals         FormatApproval[]
  records           Record[]
  sections          FormatSection[]

  @@map("formats")
}

model FormatSection {
  id          String        @id @default(cuid())
  formatId    String
  name        String
  description String?
  order       Int
  isRepeatable Boolean      @default(false)
  maxRepeat   Int?

  format      Format        @relation(fields: [formatId], references: [id])
  fields      FormatField[]

  @@map("format_sections")
}

model FormatField {
  id              String     @id @default(cuid())
  formatId        String
  sectionId       String?
  label           String
  name            String
  type            FieldType
  order           Int
  isRequired      Boolean    @default(false)
  isReadOnly      Boolean    @default(false)
  isHidden        Boolean    @default(false)
  placeholder     String?
  helpText        String?
  defaultValue    String?

  // Validaciones
  minValue        Float?
  maxValue        Float?
  minLength       Int?
  maxLength       Int?
  pattern         String?
  unit            String?
  decimalPlaces   Int?

  // Opciones (SELECT, RADIO, CHECKBOX)
  options         Json?

  // Tabla
  tableColumns    Json?

  // Calculado
  formula         String?

  // Condicional
  visibilityRule  Json?
  validationRule  Json?

  format          Format         @relation(fields: [formatId], references: [id])
  section         FormatSection? @relation(fields: [sectionId], references: [id])
  recordValues    RecordFieldValue[]

  @@map("format_fields")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  RECALLED
}

enum ApprovalRole {
  ELABORATED_BY
  REVIEWED_BY
  APPROVED_BY
  VERIFIED_BY
}

model FormatApproval {
  id          String         @id @default(cuid())
  formatId    String
  userId      String
  role        ApprovalRole
  status      ApprovalStatus @default(PENDING)
  comments    String?
  signedAt    DateTime?
  order       Int

  format      Format         @relation(fields: [formatId], references: [id])
  user        User           @relation(fields: [userId], references: [id])
  signature   ElectronicSignature[]

  @@map("format_approvals")
}

// ============================================================
// REGISTROS (INSTANCIAS DE FORMULARIOS)
// ============================================================

enum RecordStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CANCELLED
  INVALIDATED
  SUPERSEDED
}

model Record {
  id              String       @id @default(cuid())
  formatId        String
  code            String       @unique
  status          RecordStatus @default(DRAFT)
  title           String?
  batchNumber     String?
  productName     String?
  startDate       DateTime?
  endDate         DateTime?
  comments        String?

  // Invalidación (sin eliminación física - ALCOA+)
  cancelReason    String?
  cancelledAt     DateTime?
  cancelledBy     String?
  invalidReason   String?
  invalidatedAt   DateTime?
  invalidatedBy   String?

  isDeleted       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdById     String
  updatedById     String?

  format          Format       @relation(fields: [formatId], references: [id])
  createdBy       User         @relation("RecordCreator", fields: [createdById], references: [id])
  fieldValues     RecordFieldValue[]
  signatures      ElectronicSignature[]
  attachments     Attachment[]
  reports         Report[]

  @@map("records")
}

model RecordFieldValue {
  id              String    @id @default(cuid())
  recordId        String
  fieldId         String
  sectionIndex    Int       @default(0)
  value           String?
  valueNumeric    Float?
  valueDate       DateTime?
  valueJson       Json?

  // ALCOA+ - Trazabilidad de valores
  enteredAt       DateTime  @default(now())
  enteredById     String

  record          Record    @relation(fields: [recordId], references: [id])
  field           FormatField @relation(fields: [fieldId], references: [id])
  enteredBy       User      @relation(fields: [enteredById], references: [id])

  @@unique([recordId, fieldId, sectionIndex])
  @@map("record_field_values")
}

// ============================================================
// FIRMAS ELECTRÓNICAS (21 CFR Part 11)
// ============================================================

enum SignatureType {
  ELABORATED_BY
  REVIEWED_BY
  APPROVED_BY
  VERIFIED_BY
  AUTHORIZED_BY
  WITNESSED_BY
}

enum SignaturePurpose {
  FORMAT_APPROVAL
  RECORD_COMPLETION
  RECORD_APPROVAL
  RECORD_REVIEW
  DATA_ENTRY
  CORRECTION
}

model ElectronicSignature {
  id              String           @id @default(cuid())
  userId          String
  type            SignatureType
  purpose         SignaturePurpose
  meaning         String
  comments        String?

  // Referencias polimórficas
  recordId        String?
  approvalId      String?

  // 21 CFR Part 11 - Datos obligatorios
  signedAt        DateTime         @default(now())
  ipAddress       String
  userAgent       String?
  authMethod      String

  // Hash de integridad
  dataHash        String
  signatureHash   String

  isRevoked       Boolean          @default(false)
  revokedAt       DateTime?
  revokedReason   String?

  user            User             @relation(fields: [userId], references: [id])
  record          Record?          @relation(fields: [recordId], references: [id])
  approval        FormatApproval?  @relation(fields: [approvalId], references: [id])

  @@map("electronic_signatures")
}

// ============================================================
// AUDIT TRAIL (21 CFR Part 11 - Permanente e Inmutable)
// ============================================================

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  PASSWORD_RESET
  MFA_ENABLE
  MFA_DISABLE
  SIGNATURE
  EXPORT
  IMPORT
  APPROVE
  REJECT
  CANCEL
  INVALIDATE
  LOCK
  UNLOCK
  PERMISSION_CHANGE
  SESSION_REVOKE
}

enum AuditModule {
  AUTH
  USERS
  FORMATS
  RECORDS
  SIGNATURES
  REPORTS
  AUDIT
  ATTACHMENTS
  SYSTEM
}

model AuditLog {
  id              String      @id @default(cuid())
  userId          String?
  userEmail       String?
  userName        String?
  action          AuditAction
  module          AuditModule
  entityType      String?
  entityId        String?
  description     String

  // ALCOA+ - Valores antes y después
  oldValue        Json?
  newValue        Json?
  changeReason    String?

  // Metadatos de sesión
  ipAddress       String
  userAgent       String?
  sessionId       String?

  // Hash de integridad del registro
  integrityHash   String

  timestamp       DateTime    @default(now())

  // El Audit Trail NUNCA se elimina físicamente
  user            User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([module])
  @@index([entityId])
  @@index([timestamp])
  @@map("audit_logs")
}

// ============================================================
// ADJUNTOS (Archivos, Imágenes, Certificados)
// ============================================================

enum AttachmentType {
  DOCUMENT
  IMAGE
  CERTIFICATE
  PROTOCOL
  OTHER
}

model Attachment {
  id              String         @id @default(cuid())
  recordId        String
  fieldId         String?
  originalName    String
  storedName      String
  mimeType        String
  size            Int
  type            AttachmentType
  checksum        String
  description     String?
  uploadedAt      DateTime       @default(now())
  uploadedById    String

  isDeleted       Boolean        @default(false)
  deletedAt       DateTime?
  deletedBy       String?

  record          Record         @relation(fields: [recordId], references: [id])

  @@map("attachments")
}

// ============================================================
// REPORTES
// ============================================================

enum ReportFormat {
  PDF
  DOCX
  XLSX
}

enum ReportStatus {
  GENERATING
  COMPLETED
  FAILED
}

model Report {
  id              String       @id @default(cuid())
  recordId        String?
  formatId        String?
  name            String
  format          ReportFormat
  status          ReportStatus @default(GENERATING)
  filePath        String?
  fileSize        Int?
  checksum        String?
  errorMessage    String?
  generatedAt     DateTime     @default(now())
  generatedById   String

  record          Record?      @relation(fields: [recordId], references: [id])
  generatedBy     User         @relation(fields: [generatedById], references: [id])

  @@map("reports")
}

// ============================================================
// CATÁLOGOS Y CONFIGURACIÓN
// ============================================================

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("system_config")
}

model Department {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("departments")
}

model NotificationLog {
  id          String   @id @default(cuid())
  userId      String
  type        String
  subject     String
  message     String
  sentAt      DateTime @default(now())
  isRead      Boolean  @default(false)
  readAt      DateTime?

  @@map("notification_logs")
}
