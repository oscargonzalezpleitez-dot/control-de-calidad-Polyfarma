# ============================================================
# PharmaQMS - Variables de Entorno
# 21 CFR Part 11 / EU GMP Annex 11 Compliant System
# ============================================================
# IMPORTANTE: Nunca subir este archivo con valores reales al repositorio
# Copiar a .env y configurar valores seguros en producción

# --- Base de Datos ---
POSTGRES_DB=pharma_qms
POSTGRES_USER=pharma_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_16_CHARS
DATABASE_URL=postgresql://pharma_admin:CHANGE_ME@localhost:5432/pharma_qms

# --- Redis (Sesiones y Cache) ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379

# --- JWT (21 CFR Part 11 - Session Control) ---
JWT_SECRET=CHANGE_ME_MIN_256_BIT_RANDOM_STRING_FOR_PRODUCTION
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_256_BIT_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=8h

# --- Cifrado AES-256 (Datos sensibles) ---
ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARS_AES256

# --- Aplicación ---
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Email (Notificaciones y MFA) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@pharma.com
SMTP_PASS=CHANGE_ME_EMAIL_PASSWORD
SMTP_FROM=PharmaQMS <noreply@pharma.com>

# --- MFA (TOTP) ---
MFA_ISSUER=PharmaQMS
MFA_ENABLED=true

# --- Audit Trail ---
AUDIT_RETENTION_YEARS=10

# --- Backup ---
BACKUP_ENABLED=true
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=90

# --- Rate Limiting (21 CFR Part 11 - Brute Force Protection) ---
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
